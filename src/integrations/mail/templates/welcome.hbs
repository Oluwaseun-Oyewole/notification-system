        margin: 0;
        font-size: 24px;
      }
      .body {
        padding: 32px;
        color: #333;
        line-height: 1.6;
      }
      .cta {
        display: inline-block;
        margin-top: 24px;
        padding: 12px 28px;
        background: #4f46e5;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
      }
      .footer {
        padding: 20px 32px;
        background: #f9f9f9;
        color: #999;
        font-size: 12px;
        text-align: center;
      }
    </style>
